{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/packages/*": ["packages/*"],
      "@/agents/*": ["agents/*"]
    }
  },
  "include": ["*.ts", "lib/**/*", "routes/**/*", "sources/**/*"],
  "exclude": ["node_modules", "dist", "apps", "packages", "agents", "upstream", "src", "**/*.test.ts"]
}
