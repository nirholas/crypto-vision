{
  "name": "crypto-vision",
  "version": "0.1.0",
  "description": "The complete cryptocurrency intelligence API — cryptocurrency.cv",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/src/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docker:build": "docker build -t crypto-vision .",
    "docker:run": "docker run -p 8080:8080 --env-file .env crypto-vision"
  },
  "dependencies": {
    "@google-cloud/aiplatform": "^6.5.0",
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@hono/node-server": "^1.13.0",
    "@hono/node-ws": "^1.3.0",
    "hono": "^4.7.0",
    "ioredis": "^5.4.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "undici": "^7.3.0",
    "ws": "^8.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@google-cloud/bigquery": "^8.1.1",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "author": "nirholas",
  "repository": {
    "type": "git",
    "url": "https://github.com/nirholas/crypto-vision"
  }
}
