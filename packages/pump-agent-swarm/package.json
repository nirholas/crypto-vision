{
  "name": "@nirholas/pump-agent-swarm",
  "version": "0.1.0",
  "description": "Pump.fun agent swarm — creator agents mint tokens, trader agents trade them, all coordinated via x402 micropayments",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pump-swarm": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agents": {
      "types": "./dist/agents/index.d.ts",
      "import": "./dist/agents/index.js"
    },
    "./trading": {
      "types": "./dist/trading/index.d.ts",
      "import": "./dist/trading/index.js"
    },
    "./bundle": {
      "types": "./dist/bundle/index.d.ts",
      "import": "./dist/bundle/index.js"
    },
    "./intelligence": {
      "types": "./dist/intelligence/index.d.ts",
      "import": "./dist/intelligence/index.js"
    },
    "./coordination": {
      "types": "./dist/coordination/index.d.ts",
      "import": "./dist/coordination/index.js"
    },
    "./dashboard": {
      "types": "./dist/dashboard/index.d.ts",
      "import": "./dist/dashboard/index.js"
    },
    "./infra": {
      "types": "./dist/infra/index.d.ts",
      "import": "./dist/infra/index.js"
    },
    "./demo": {
      "types": "./dist/demo/index.d.ts",
      "import": "./dist/demo/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postinstall": "node scripts/postinstall.cjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:dev": "npx tsx src/index.ts",
    "start:creator": "npx tsx src/agents/creator-agent.ts",
    "start:trader": "npx tsx src/agents/trader-agent.ts",
    "start:swarm": "npx tsx src/swarm.ts",
    "start:screener": "npx tsx -e \"import { startFromEnv } from './src/api/screener-server.js'; startFromEnv();\"",
    "cli": "npx tsx src/cli.ts",
    "cli:interactive": "npx tsx src/demo/cli-runner.ts",
    "demo": "npx tsx src/demo/mock-presentation-demo.ts",
    "demo:full": "npx tsx src/demo/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "pump-fun",
    "agent-swarm",
    "x402",
    "solana",
    "bonding-curve",
    "meme-coin",
    "ai-agent",
    "trading-bot"
  ],
  "author": "nirholas",
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.0",
    "@hono/node-server": "^1.19.10",
    "@pump-fun/pump-sdk": "github:nirholas/pump-fun-sdk",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "bip39": "^3.1.0",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0",
    "ed25519-hd-key": "^1.3.0",
    "eventemitter3": "^5.0.1",
    "hono": "^4.12.4",
    "nanoid": "^5.0.0",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.44.0",
    "tweetnacl": "^1.0.3",
    "uuid": "^13.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/bn.js": "^5.1.6",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "bigint-buffer": "file:./lib/bigint-buffer-safe"
  }
}
