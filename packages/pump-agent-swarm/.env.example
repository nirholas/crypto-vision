# ─── Solana RPC ──────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=

# ─── Swarm Wallet (base58 secret key or mnemonic) ───────────────
# SWARM_MASTER_KEY=

# ─── Analytics / x402 ───────────────────────────────────────────
ANALYTICS_API_URL=
X402_PRIVATE_KEY=

# ─── AI / LLM (narrative agent) ─────────────────────────────────
OPENAI_API_KEY=

# ─── Storage (metadata / images) ────────────────────────────────
NFT_STORAGE_API_KEY=
WEB3_STORAGE_API_KEY=
STABILITY_API_KEY=

# ─── Telegram Bot ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=           # comma-separated chat IDs

# ─── Swarm Behaviour ────────────────────────────────────────────
TRADER_COUNT=3
STRATEGY=organic                      # organic | volume | graduation | exit
DEV_BUY_SOL=0.5
LOG_LEVEL=info                        # debug | info | warn | error
